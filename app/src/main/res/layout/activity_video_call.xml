<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".Activities.VideoCallActivity">

    <!-- Remote Video View (Advisor Video) -->
    <FrameLayout
        android:id="@+id/remoteVideoView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@color/black" />

    <!-- Top Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/circle_bg_translucent"
            android:padding="10dp"
            android:src="@drawable/arrow_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:tint="@color/white" />

        <LinearLayout
            android:id="@+id/statusPill"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/bg_status_pill"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_circle_red"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btnMore"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/circle_bg_translucent"
            android:padding="10dp"
            android:src="@drawable/ic_more_vert"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:tint="@color/white" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Local Video View (User's own video) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/localVideoContainer"
        android:layout_width="110dp"
        android:layout_height="160dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/dark_gray"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:id="@+id/localVideoView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/tvYouLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="12dp"
            android:background="@drawable/bg_label_glass"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="You"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold" />

    </androidx.cardview.widget.CardView>

    <!-- Connecting / Background UI -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/connectingContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:visibility="visible">

        <View
            android:id="@+id/ringOuter"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:background="@drawable/bg_connecting_ring"
            android:alpha="0.3"
            app:layout_constraintBottom_toBottomOf="@id/ringInner"
            app:layout_constraintEnd_toEndOf="@id/ringInner"
            app:layout_constraintStart_toStartOf="@id/ringInner"
            app:layout_constraintTop_toTopOf="@id/ringInner" />

        <View
            android:id="@+id/ringMiddle"
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:background="@drawable/bg_connecting_ring"
            android:alpha="0.6"
            app:layout_constraintBottom_toBottomOf="@id/ringInner"
            app:layout_constraintEnd_toEndOf="@id/ringInner"
            app:layout_constraintStart_toStartOf="@id/ringInner"
            app:layout_constraintTop_toTopOf="@id/ringInner" />

        <View
            android:id="@+id/ringInner"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/bg_connecting_ring"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivConnectingIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_medical_bag"
            app:layout_constraintBottom_toBottomOf="@id/ringInner"
            app:layout_constraintEnd_toEndOf="@id/ringInner"
            app:layout_constraintStart_toStartOf="@id/ringInner"
            app:layout_constraintTop_toTopOf="@id/ringInner" />

        <TextView
            android:id="@+id/tvConnectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:text="Connecting to Dr. Jenny..."
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ringInner" />

        <TextView
            android:id="@+id/tvEstablishingLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:letterSpacing="0.2"
            android:text="ESTABLISHING SECURE LINK"
            android:textColor="#80FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvConnectionStatus" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Advisor Details -->
    <LinearLayout
        android:id="@+id/advisorDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/bottomControler">

        <TextView
            android:id="@+id/tvAdvisorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dr. Jenny Wilson"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAdvisorSpecialty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Dermatologist • General Hospital"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvPaymentInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text=""
            android:textColor="@color/white"
            android:textSize="14sp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Bottom Controls -->
    <LinearLayout
        android:id="@+id/bottomControler"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="40dp"
        android:background="@drawable/bg_video_call_controls"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/btnMute"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_margin="@dimen/_5sdp"
            android:layout_weight="1"
            android:background="@drawable/circle_bg_translucent"
            android:padding="14dp"
            android:src="@drawable/mic" />

        <ImageView
            android:id="@+id/btnVideoToggle"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/circle_bg_translucent"
            android:padding="14dp"
            android:layout_margin="@dimen/_5sdp"
            android:src="@drawable/camera_turnon" />

        <ImageView
            android:id="@+id/btnEndCall"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:layout_weight="1.2"
            android:background="@drawable/bg_circle_red"
            android:elevation="8dp"
            android:layout_margin="@dimen/_5sdp"
            android:padding="18dp"
            android:src="@drawable/telephone"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/btnSwitchCamera"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/circle_bg_translucent"
            android:padding="14dp"
            android:layout_margin="@dimen/_5sdp"

            android:src="@drawable/video" />

        <ImageView
            android:id="@+id/btnChat"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/circle_bg_translucent"
            android:padding="14dp"
            android:layout_margin="@dimen/_5sdp"
            android:src="@drawable/chat" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

